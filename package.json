{
  "name": "mamoru-tana",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "store:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/store-readiness.ps1",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "release:check": "npm run store:check && npm run typecheck && expo install --check && expo-doctor && expo export --platform web && npm audit --audit-level=high --omit=dev",
    "start:node20": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-node20.ps1",
    "release:check:node20": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-check-node20.ps1"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.18",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^1.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "expo-doctor": "1.19.10",
    "typescript": "~6.0.3"
  }
}
